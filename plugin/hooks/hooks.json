{
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "agentic-clustering:proposer|agentic-clustering:synthesizer|agentic-clustering:auditor|agentic-clustering:investigator|agentic-clustering:critic",
        "hooks": [
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/skills/corpus-tools/scripts/validate.py\""
          },
          {
            "type": "command",
            "command": "uv run \"${CLAUDE_PLUGIN_ROOT}/skills/corpus-tools/scripts/state.py\" summarize"
          }
        ]
      }
    ]
  }
}
